# ============================================================
# Multi-Agent Investment Research — environment configuration
#
# Per-job schedule (times, queries, recipients) is configured in
#   config/schedule.json
# Copy config/schedule.example.json to config/schedule.json and edit
# it. This .env file only holds:
#   - App-wide settings (LLM, agents, logging)
#   - Sender credentials (SMTP)
#   - Daemon master toggles (auto-run, run-on-startup)
# ============================================================

# ─── DeepSeek API ────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ─── LLM Settings ────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ─── Bull vs Bear Debate ─────────────────────────────────────
DEBATE_MAX_ROUNDS=2
DEBATE_TEMPERATURE=0.7

# ─── Agent runtime ───────────────────────────────────────────
AGENT_TIMEOUT=30
LOG_LEVEL=INFO

# ─── QQ Mail SMTP (sender credentials) ───────────────────────
# Recipients are NOT here — they live per-job in config/schedule.json
#
# How to get your QQ Mail authorization code:
#   1. Open https://mail.qq.com
#   2. Settings -> Account -> POP3/IMAP/SMTP service
#   3. Enable IMAP/SMTP, generate authorization code
#   4. Use the 16-char code below (NOT your QQ password)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
QQ_EMAIL=your_qq_account@qq.com
QQ_EMAIL_PASSWORD=your_16_char_authorization_code
QQ_EMAIL_SENDER_NAME=AI Investment Research

# ─── Scheduler ──────────────────────────────────────────────
# All scheduling (enabled, run_on_startup, jobs, times, queries,
# recipients) lives in config/schedule.json. See schedule.example.json.
#
# run.bat / run.sh always launch the daemon. The daemon reads
# config/schedule.json and respects its 'enabled' field — if false,
# it exits cleanly without running any jobs.
#
# (Backward compat: if config/schedule.json is missing, the daemon
# falls back to env vars AUTO_RUN_SCHEDULE / RUN_ON_STARTUP / WATCHLIST
# / SCHEDULE_DAILY_TIMES / QQ_EMAIL_RECIPIENTS.)
