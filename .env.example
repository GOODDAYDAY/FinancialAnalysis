# DeepSeek API Configuration
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# LLM Settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Debate Settings
DEBATE_MAX_ROUNDS=2
DEBATE_TEMPERATURE=0.7

# Agent Settings
AGENT_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# ============================================================
# Scheduled Email Notification (QQ Mail)
# ============================================================
# Watchlist: comma-separated tickers to analyze on schedule
WATCHLIST=600519.SS,000858.SZ,300750.SZ

# Watchlist entries can be either:
#   - Bare ticker symbols (wrapped as "Analyze {ticker}", English report)
#   - Full natural-language queries (language auto-detected from the query text)
# Examples:
#   WATCHLIST=600519.SS,000858.SZ,300750.SZ
#   WATCHLIST=Analyze AAPL,分析贵州茅台,Tell me about TSLA
#   WATCHLIST=分析600519.SS,Analyze MSFT
# Chinese queries -> Chinese reports/emails. English queries -> English.

# ----- Built-in scheduler daemon (started by run.bat / run.sh) -----
# When true, run.bat / run.sh spawn scripts/scheduler_daemon.py alongside Streamlit.
AUTO_RUN_SCHEDULE=false

# When true, daemon runs scheduled_analysis.py once immediately at startup,
# then continues looping per the schedule below.
RUN_ON_STARTUP=true

# Schedule mode: "daily" or "interval"
SCHEDULE_MODE=daily

# Daily mode: one OR multiple HH:MM times per day, comma-separated.
# All times are LOCAL time on the host machine.
# Common patterns:
#   SCHEDULE_DAILY_TIMES=17:30                    # once after market close
#   SCHEDULE_DAILY_TIMES=08:30,13:00,20:00        # before open, midday, evening
#   SCHEDULE_DAILY_TIMES=09:00,11:30,13:30,15:30  # every A-share session boundary
SCHEDULE_DAILY_TIMES=08:30,13:00,20:00

# (Deprecated alias: SCHEDULE_DAILY_TIME — singular form, used as fallback
# when SCHEDULE_DAILY_TIMES is not set.)

# Used when SCHEDULE_MODE=daily — skip Saturdays and Sundays
SCHEDULE_WEEKDAYS_ONLY=true

# Used when SCHEDULE_MODE=interval — hours between runs
SCHEDULE_INTERVAL_HOURS=24

# QQ Mail SMTP Configuration
# Get your authorization code from QQ Mail web settings:
#   1. Open https://mail.qq.com
#   2. Settings -> Account -> POP3/IMAP/SMTP service
#   3. Enable IMAP/SMTP, generate authorization code
#   4. Use the 16-char code below (NOT your QQ password)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
QQ_EMAIL=your_qq_account@qq.com
QQ_EMAIL_PASSWORD=your_16_char_authorization_code
QQ_EMAIL_SENDER_NAME=AI Investment Research

# Recipients: one OR multiple email addresses, comma-separated.
# Spaces around commas are OK. Whitespace is trimmed automatically.
# Examples:
#   QQ_EMAIL_RECIPIENTS=alice@qq.com
#   QQ_EMAIL_RECIPIENTS=alice@qq.com,bob@gmail.com
#   QQ_EMAIL_RECIPIENTS=alice@qq.com, bob@gmail.com, carol@163.com
QQ_EMAIL_RECIPIENTS=alice@qq.com,bob@gmail.com
